# ============================================================================
#  Aegis server environment template
#  Mantle Turing Test Hackathon — Track 3: AI × RWA
# ============================================================================

# Express / Mongo
PORT=3001
MONGODB_URI=mongodb+srv://USER:PASS@cluster0.xxxx.mongodb.net/aegis?retryWrites=true&w=majority
CLIENT_URL=http://localhost:5173

# ============================================================================
#  Mantle Network — primary integration target
# ============================================================================
MANTLE_NETWORK=testnet                              # testnet | mainnet
MANTLE_SEPOLIA_RPC=https://rpc.sepolia.mantle.xyz
MANTLE_MAINNET_RPC=https://rpc.mantle.xyz
MANTLE_CHAIN_ID=5003                                # 5003 = Mantle Sepolia, 5000 = Mantle

# Deployed Mantle addresses (output of contracts/scripts/deploy.js)
VAULT_CONTRACT_ADDRESS=                             # AegisVault on Mantle
USDY_ADDRESS=                                       # USDY (deposit/settlement, 6dp)
METH_ADDRESS=                                       # mETH (hedge target)

# Relayer key — signs settleShield and (optional) gas top-ups. Must match the
# relayer the vault was deployed with. 64 hex chars, with or without 0x.
RELAYER_PRIVATE_KEY=

# Protocol fee (basis points) skimmed from positive payouts only
PROTOCOL_FEE_BPS=1000

# Relayer-sponsored shield-creation gas top-up amounts (native MNT)
SPONSOR_GAS_TOPUP_MNT=0.02
SPONSOR_GAS_THRESHOLD_MNT=0.005

# ============================================================================
#  Auditable shield-envelope storage
#    hash   -> keccak256 rootHash only (default)
#    pinata -> also pin the envelope JSON to IPFS (needs PINATA_JWT)
# ============================================================================
STORAGE_PROVIDER=hash
PINATA_JWT=
PINATA_GATEWAY=https://gateway.pinata.cloud/ipfs

# ============================================================================
#  AI risk engine
#  The active model is provider-agnostic and selected at RUNTIME from the
#  gated /admin panel (persisted in Mongo) — no model/key needs to be set here.
#  Optionally, a fallback API key may be provided via the environment instead.
# ============================================================================
# (configure the AI engine from /admin after deploy)
