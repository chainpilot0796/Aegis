# ============================================================================
#  Aegis.0G server environment template
# ============================================================================

# Express / Mongo
PORT=3001
MONGODB_URI=mongodb+srv://USER:PASS@cluster0.xxxx.mongodb.net/aegis?retryWrites=true&w=majority
CLIENT_URL=http://localhost:5173
# Internal trade API base — used by legacy Elsa intent routing (not in demo path)
API_BASE_URL=http://127.0.0.1:3001

# ============================================================================
#  Mantle Network — PRIMARY integration target (Mantle Turing Test Hackathon)
# ============================================================================
MANTLE_NETWORK=testnet                              # testnet | mainnet
MANTLE_SEPOLIA_RPC=https://rpc.sepolia.mantle.xyz
MANTLE_MAINNET_RPC=https://rpc.mantle.xyz
MANTLE_CHAIN_ID=5003                                # 5003 = Mantle Sepolia, 5000 = Mantle

# Deployed Mantle addresses (output of the ported contracts deploy script).
# RELAYER_PRIVATE_KEY (below, shared) signs settleShield + sponsor gas top-ups.
VAULT_CONTRACT_ADDRESS=                             # AegisVault on Mantle  <-- TODO: set after deploy
USDY_ADDRESS=                                       # USDY (deposit/settlement, 6dp MockRWAToken) <-- TODO
METH_ADDRESS=                                       # mETH (hedge target, MockRWAToken)          <-- TODO

# Protocol fee (basis points) skimmed from positive payouts only (read by setProtocolFee tooling)
PROTOCOL_FEE_BPS=0

# Relayer-sponsored (gasless-ish) shield creation gas top-up amounts (native MNT)
SPONSOR_GAS_TOPUP_MNT=0.02
SPONSOR_GAS_THRESHOLD_MNT=0.005

# ----------------------------------------------------------------------------
#  Chain-neutral storage for the auditable shield envelope (Mantle path)
#    STORAGE_PROVIDER=pinata -> pin envelope JSON to IPFS (needs PINATA_JWT)
#    STORAGE_PROVIDER=hash   -> hash-only mode (returns keccak rootHash only)
#  NOTE: the legacy 0G path also reads STORAGE_PROVIDER (zerog|fileverse|hash).
# ----------------------------------------------------------------------------
# STORAGE_PROVIDER=pinata
PINATA_GATEWAY=https://gateway.pinata.cloud/ipfs
# PINATA_JWT set in the legacy block below

# ============================================================================
#  0G Chain — legacy integration target (kept for back-compat, not the demo path)
# ============================================================================
ZG_NETWORK=testnet                                  # testnet | mainnet
ZG_TESTNET_RPC=https://evmrpc-testnet.0g.ai
ZG_MAINNET_RPC=https://evmrpc.0g.ai
ZG_FALLBACK_RPC_MAINNET=                            # Ankr / dRPC backup

# Single key funds storage uploads + compute broker + (legacy) settlement
RELAYER_PRIVATE_KEY=                                # 64 hex chars, with or without 0x
# Override per-service if you want isolated keys:
ZG_STORAGE_PRIVATE_KEY=
ZG_COMPUTE_PRIVATE_KEY=

# Deployed contract addresses (output of contracts/scripts/deploy.js)
VAULT_CONTRACT_ADDRESS=                             # AegisVault address
USDC_ADDRESS=                                       # AUSDC address

# ============================================================================
#  0G Storage  (@0gfoundation/0g-ts-sdk)
# ============================================================================
ZG_INDEXER_URL=https://indexer-storage-testnet-turbo.0g.ai
# Storage provider precedence in sponsorService.createShieldDoc:
#   zerog    -> 0G Storage (canonical)
#   fileverse -> legacy Fileverse / Pinata IPFS path
#   hash     -> deterministic content hash, no off-chain persistence
STORAGE_PROVIDER=zerog

# ============================================================================
#  0G Compute  (@0gfoundation/0g-compute-ts-sdk)
# ============================================================================
# Pin a specific provider; leave blank to auto-pick a TeeML-verifiable one.
ZG_COMPUTE_PROVIDER_PIN=
ZG_COMPUTE_MODEL_HINT=

# ============================================================================
#  Silent inference fallbacks (in order of preference)
# ============================================================================
NIM_API_KEY=
NIM_BASE_URL=https://integrate.api.nvidia.com/v1
NIM_MODEL=meta/llama-3.3-70b-instruct

OPENAI_API_KEY=                                     # last-resort fallback
OPENAI_MODEL=gpt-4o-mini

# ============================================================================
#  Legacy: Base Sepolia / BitGo / Fileverse / ENS / Twilio / Parcl
#  Kept in the repo for back-compat; not required for the Aegis.0G demo path.
# ============================================================================
BASE_SEPOLIA_RPC=https://sepolia.base.org

PINATA_JWT=                                         # IPFS pinning for the Mantle shield envelope (STORAGE_PROVIDER=pinata)
# PINATA_GATEWAY set in the Mantle storage block above
PIMLICO_API_KEY=

ENS_REGISTRAR_ADDRESS=
ENS_SEPOLIA_RPC=https://ethereum-sepolia-rpc.publicnode.com
ENS_REGISTRAR_PRIVATE_KEY=

BITGO_ACCESS_TOKEN=
BITGO_ENTERPRISE_ID=
BITGO_CUSTODY_COIN=tbaseeth
BITGO_WALLET_PASSPHRASE=
BITGO_EXPRESS_HOST=http://localhost:3080
# BITGO_RELAYER_FALLBACK_TESTNET=true

COINGECKO_API_KEY=
OILPRICE_API_KEY=

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

HEYELSA_PAYMENT_PRIVATE_KEY=
HEYELSA_API_URL=https://x402-api.heyelsa.ai
BASE_MAINNET_RPC=https://mainnet.base.org
