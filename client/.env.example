# ============================================================================
#  Aegis client (Vite) environment template — Mantle network
# ============================================================================

# Which Mantle network the dapp targets (mainnet | testnet)
VITE_NETWORK=testnet

# RPCs (optional — falls back to public defaults)
VITE_MANTLE_TESTNET_RPC=https://rpc.sepolia.mantle.xyz
VITE_MANTLE_MAINNET_RPC=https://rpc.mantle.xyz

# Block explorer for tx/address links
VITE_EXPLORER_BASE=https://sepolia.mantlescan.xyz
# For mainnet: https://mantlescan.xyz

# Deployed contract addresses (output of contracts/scripts/deploy.js)
VITE_USDY_ADDRESS=
VITE_METH_ADDRESS=
VITE_AEGIS_VAULT_ADDRESS=

# Backend API
VITE_API_BASE_URL=http://localhost:3001

# WalletConnect (RainbowKit) — get one at https://cloud.walletconnect.com
VITE_WALLETCONNECT_PROJECT_ID=
